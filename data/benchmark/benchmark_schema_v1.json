{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VideoQA Benchmark Item v1",
  "type": "object",
  "required": [
    "question_id",
    "video_id",
    "question",
    "gold_answer",
    "question_type",
    "gold_evidence"
  ],
  "properties": {
    "question_id": { "type": "string" },
    "video_id": { "type": "string" },
    "question": { "type": "string" },
    "gold_answer": { "type": "string" },
    "question_type": {
      "type": "string",
      "enum": ["factoid", "procedure", "temporal", "visual", "multimodal", "other"]
    },
    "gold_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["video_id", "modality", "timestamp_start", "timestamp_end"],
        "properties": {
          "video_id": { "type": "string" },
          "modality": { "type": "string", "enum": ["text", "frame", "mixed"] },
          "timestamp_start": { "type": "number" },
          "timestamp_end": { "type": "number" },
          "source_ids": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
